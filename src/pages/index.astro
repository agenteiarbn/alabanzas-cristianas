---
import Layout from "../layouts/Layout.astro";
import SongCard from "../components/SongCard.astro";
import { getCanciones, getCategorias } from "../lib/supabase";

const url = new URL(Astro.request.url);
const q    = url.searchParams.get("q")?.trim() ?? "";
const cat  = url.searchParams.get("cat") ?? "todas";
const page = Math.max(1, Number(url.searchParams.get("page") ?? "1"));

const resultado = await getCanciones(page, cat);

const canciones = q
  ? resultado.data.filter((c) =>
      c.titulo.toLowerCase().includes(q.toLowerCase()) ||
      c.artistas.nombre.toLowerCase().includes(q.toLowerCase()))
  : resultado.data;

const totalPages = Math.ceil(resultado.total / 12);

function pageUrl(p: number) {
  const u = new URL(url);
  u.searchParams.set("page", String(p));
  return u.pathname + u.search;
}
---

<Layout
  title="Alabanzas Cristianas — Letras de Adoraciones y Alabanza"
  description={`Encuentra letras de adoraciones y alabanzas cristianas en español. Más de ${resultado.total} canciones.`}
>
  <!-- Hero decorativo -->
  <header class="site-header container">
    <div class="eyebrow">✦ ✝ ✦</div>
    <h1>Alabanzas<br />&amp; Adoraciones</h1>
    <p class="tagline">Letras de canciones que elevan el alma</p>
    <div class="gold-rule"></div>
  </header>

  <div class="container">
    <p class="result-count" id="result-count">
      {canciones.length} {canciones.length === 1 ? "canción" : "canciones"} encontradas
    </p>

    <div class="songs-grid" id="songs-grid">
      {canciones.length === 0 ? (
        <div class="empty-state">No se encontraron canciones{q ? ` para "${q}"` : ""}.</div>
      ) : (
        canciones.map((cancion, i) => <SongCard cancion={cancion} index={i} />)
      )}
    </div>

    {totalPages > 1 && !q && (
      <nav class="pagination" aria-label="Páginas">
        {page > 1 && <a href={pageUrl(page - 1)} class="page-link">← Anterior</a>}
        {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
          <a href={pageUrl(p)} class={`page-link${p === page ? " active" : ""}`}>{p}</a>
        ))}
        {page < totalPages && <a href={pageUrl(page + 1)} class="page-link">Siguiente →</a>}
      </nav>
    )}
  </div>
</Layout>

<style>
  .pagination { display: flex; gap: .5rem; justify-content: center; margin-top: 2.5rem; flex-wrap: wrap; padding-bottom: 2rem; }
  .page-link { padding: .45rem .85rem; border: 1px solid #3a2e1e; border-radius: 4px; color: #a89060; text-decoration: none; font-size: .9rem; }
  .page-link:hover { border-color: var(--gold); color: var(--gold); }
  .page-link.active { background: var(--gold); color: #0d0d0d; border-color: var(--gold); font-weight: bold; }
</style>

<script define:vars={{ cat }}>
  // Búsqueda en tiempo real usando el input del header
  const input = document.getElementById('header-search');
  const grid  = document.getElementById('songs-grid');
  const count = document.getElementById('result-count');
  if (!input || !grid || !count) throw new Error('missing elements');

  let timer;
  input.addEventListener('input', () => {
    clearTimeout(timer);
    timer = setTimeout(async () => {
      const q = input.value.trim();
      const params = new URLSearchParams({ cat });
      if (q) params.set('q', q);

      try {
        const res  = await fetch(`/api/songs?${params}`);
        const json = await res.json();
        if (!json.ok) return;

        const songs = json.data;
        count.textContent = `${songs.length} ${songs.length === 1 ? 'canción' : 'canciones'} encontradas`;

        if (songs.length === 0) {
          grid.innerHTML = `<div class="empty-state">No se encontraron canciones${q ? ` para "${q}"` : ''}.</div>`;
          return;
        }

        grid.innerHTML = songs.map((c, i) => `
          <div class="song-card-wrap">
            <a href="/cancion/${c.slug}" class="song-card" style="animation-delay:${i * 0.05}s">
              <span class="card-badge">✦ ${c.categorias.nombre}</span>
              <h2 class="card-title">${c.titulo}</h2>
              <p class="card-artist">${c.artistas.nombre}</p>
              <p class="card-preview">${(c.letra.split('\n').find(l => l.trim()) ?? '').replace(/</g,'&lt;')}</p>
              <div class="card-meta">
                ${c.tono ? `<span class="card-tono">${c.tono}</span>` : ''}
                <span class="card-arrow">→</span>
              </div>
            </a>
            <button class="heart-btn" data-heart data-id="${c.id}" title="Guardar en favoritos" aria-label="Guardar en favoritos">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </button>
          </div>
        `).join('');
      } catch {}
    }, 300);
  });
</script>
