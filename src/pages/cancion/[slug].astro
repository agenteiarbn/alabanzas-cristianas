---
import Layout from "../../layouts/Layout.astro";
import { getCancion } from "../../lib/supabase";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/");

const cancion = await getCancion(slug);
if (!cancion) return Astro.redirect("/");

function youtubeId(url: string | null): string | null {
  if (!url) return null;
  const m = url.match(/(?:v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
  return m ? m[1] : null;
}

const ytId = youtubeId(cancion.youtube_url);

const artistInitial = cancion.artistas.nombre.charAt(0).toUpperCase();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MusicComposition",
  "name": cancion.titulo,
  "composer": { "@type": "Person", "name": cancion.artistas.nombre },
  "inLanguage": "es",
  "genre": cancion.categorias.nombre,
  ...(cancion.anio ? { "dateCreated": String(cancion.anio) } : {}),
};
---

<Layout
  title={`${cancion.titulo} — ${cancion.artistas.nombre} | Alabanzas Cristianas`}
  description={`Letra de "${cancion.titulo}" por ${cancion.artistas.nombre}. ${cancion.letra.split('\n').find(l => l.trim()) ?? ''}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <div class="container">
    <a href="/" class="back-link">← Volver al catálogo</a>

    <!-- ── SONG META HEADER ── -->
    <div class="song-meta-header">
      <div class="artist-thumb" aria-hidden="true">
        <span class="artist-thumb-initial">{artistInitial}</span>
      </div>
      <div class="song-meta-info">
        <h1 class="detail-title">{cancion.titulo}</h1>
        <p class="detail-artist">{cancion.artistas.nombre}</p>
      </div>
      <div class="song-meta-right">
        <span class="detail-cat-label">categoría</span>
        <span class="detail-cat-value">✦ {cancion.categorias.nombre}</span>
      </div>
    </div>

    <!-- ── TABS ── -->
    <div class="song-tabs">
      <span class="song-tab song-tab--active">Letra</span>
      {cancion.tono  && <span class="song-tab">Tono: {cancion.tono}</span>}
      {cancion.anio  && <span class="song-tab">{cancion.anio}</span>}
      {cancion.artistas.pais && <span class="song-tab">{cancion.artistas.pais}</span>}
    </div>

    <!-- ── 2-COLUMN LAYOUT ── -->
    <div class={`song-layout${ytId ? "" : " song-layout--no-sidebar"}`}>

      <!-- Left actions bar -->
      <div class="left-actions" aria-hidden="true">
        <button class="action-icon" data-heart data-id={cancion.id} title="Guardar en favoritos" aria-label="Guardar en favoritos">♡</button>
        <button class="action-icon" title="Compartir">↗</button>
        <button class="action-icon" title="Imprimir">⊞</button>
        <a
          href={`/api/cancion/${cancion.slug}/propresenter`}
          download={`${cancion.slug}.pro6`}
          class="action-icon action-icon--download"
          title="Descargar para ProPresenter (.pro6)"
          aria-label="Descargar para ProPresenter"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          <span class="action-icon-label">ProPresenter</span>
        </a>
      </div>

      <!-- Lyrics -->
      <div class="lyrics-block" aria-label="Letra de la canción">
        {cancion.letra}
      </div>

      <!-- Right sidebar: video -->
      {ytId && (
        <aside class="song-sidebar">
          <p class="sidebar-label">▶ Escuchar</p>
          <iframe
            src={`https://www.youtube.com/embed/${ytId}`}
            title={`${cancion.titulo} — ${cancion.artistas.nombre}`}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </aside>
      )}
    </div>
  </div>
</Layout>
