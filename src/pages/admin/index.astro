---
import { getAllCanciones } from "../../lib/supabase-admin";

const token = Astro.locals.token!;
const canciones = await getAllCanciones(token);
const error = Astro.url.searchParams.get("error");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Canciones</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { background: #0d0d0d; color: #e8dcc8; font-family: Georgia, serif; padding: 2rem; }
      .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
      h1 { font-size: 1.4rem; color: #d4af5f; }
      .actions { display: flex; gap: .75rem; align-items: center; }
      .btn { padding: .5rem 1.1rem; background: #d4af5f; border: none; border-radius: 4px; color: #0d0d0d; font-weight: bold; cursor: pointer; text-decoration: none; font-size: .9rem; white-space: nowrap; }
      .btn:hover { background: #e8c870; }
      .btn-ghost { background: transparent; border: 1px solid #3a2e1e; color: #a89060; }
      .btn-ghost:hover { border-color: #d4af5f; color: #d4af5f; background: transparent; }
      .error { margin-bottom: 1.25rem; padding: .65rem 1rem; background: #3a1010; border: 1px solid #8b2020; border-radius: 4px; font-size: .875rem; color: #f08080; }
      table { width: 100%; border-collapse: collapse; font-size: .9rem; }
      th { text-align: left; padding: .75rem 1rem; background: #1a1a1a; color: #a89060; font-size: .78rem; text-transform: uppercase; letter-spacing: .06em; border-bottom: 1px solid #3a2e1e; }
      td { padding: .75rem 1rem; border-bottom: 1px solid #191919; vertical-align: middle; }
      tr:hover td { background: #111; }
      .badge { display: inline-block; padding: .2rem .55rem; border-radius: 999px; font-size: .75rem; font-family: sans-serif; }
      .pub { background: #1a3a1a; color: #6bcf6b; }
      .bor { background: #3a1a1a; color: #e07070; }
      a.link { color: #d4af5f; text-decoration: none; }
      a.link:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <div class="topbar">
      <h1>✝ Canciones <span style="color:#a89060;font-size:1rem;">({canciones.length})</span></h1>
      <div class="actions">
        <a href="/admin/canciones/nueva" class="btn">+ Nueva canción</a>
        <a href="/" class="btn btn-ghost">Ver sitio</a>
        <form method="post" action="/api/admin/logout" style="margin:0">
          <button type="submit" class="btn btn-ghost">Salir</button>
        </form>
      </div>
    </div>

    {error && <div class="error">{error}</div>}

    <table>
      <thead>
        <tr>
          <th>Título</th>
          <th>Artista</th>
          <th>Categoría</th>
          <th>Tono</th>
          <th>Estado</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {canciones.map((c) => (
          <tr>
            <td><a class="link" href={`/admin/canciones/${c.id}`}>{c.titulo}</a></td>
            <td>{c.artistas.nombre}</td>
            <td>{c.categorias.nombre}</td>
            <td>{c.tono ?? "—"}</td>
            <td>
              {c.publicada
                ? <span class="badge pub">Publicada</span>
                : <span class="badge bor">Borrador</span>}
            </td>
            <td><a class="link" href={`/admin/canciones/${c.id}`}>Editar</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </body>
</html>
