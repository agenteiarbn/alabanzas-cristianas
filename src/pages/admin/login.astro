---
const error = Astro.url.searchParams.get("error");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin — Alabanzas Cristinas</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { background: #0d0d0d; color: #e8dcc8; font-family: Georgia, serif; display: grid; place-items: center; min-height: 100vh; }
      .card { background: #1a1a1a; border: 1px solid #3a2e1e; border-radius: 8px; padding: 2.5rem; width: 100%; max-width: 380px; }
      h1 { font-size: 1.4rem; color: #d4af5f; margin-bottom: 1.5rem; text-align: center; letter-spacing: .05em; }
      label { display: block; font-size: .85rem; color: #a89060; margin-bottom: .35rem; margin-top: 1.25rem; }
      input { width: 100%; padding: .65rem .85rem; background: #111; border: 1px solid #3a2e1e; border-radius: 4px; color: #e8dcc8; font-size: 1rem; }
      input:focus { outline: none; border-color: #d4af5f; }
      .btn { margin-top: 1.75rem; width: 100%; padding: .75rem; background: #d4af5f; border: none; border-radius: 4px; color: #0d0d0d; font-size: 1rem; font-weight: bold; cursor: pointer; letter-spacing: .03em; }
      .btn:hover { background: #e8c870; }
      .error { margin-top: 1rem; padding: .65rem 1rem; background: #3a1010; border: 1px solid #8b2020; border-radius: 4px; font-size: .875rem; color: #f08080; text-align: center; }
    </style>
  </head>
  <body>
    <div class="card">
      <h1>✝ Panel de Administración</h1>
      {error && <p class="error">Correo o contraseña incorrectos.</p>}
      <form method="post" action="/api/admin/login">
        <label for="email">Correo electrónico</label>
        <input id="email" name="email" type="email" required autocomplete="email" />
        <label for="password">Contraseña</label>
        <input id="password" name="password" type="password" required autocomplete="current-password" />
        <button class="btn" type="submit">Entrar</button>
      </form>
    </div>
  </body>
</html>
