---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="¡Suscripción activada! — Alabanzas Cristianas"
  description="Tu suscripción Premium está activa."
>
  <div class="container">
    <div class="subs-success">
      <span class="subs-success-icon">✝</span>
      <h1>¡Gracias por suscribirte!</h1>
      <p>
        Tu suscripción <strong>Premium Anual</strong> está activa.<br>
        Ya puedes disfrutar de todas las funciones sin límites.
      </p>
      <a href="/perfil" class="subs-cta" style="display:inline-flex;align-items:center;gap:.5rem;text-decoration:none;max-width:280px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        Ver mi perfil
      </a>
      <p style="margin-top:1.25rem;">
        <a href="/" style="color:var(--gold);text-decoration:none;font-size:.9rem;">
          ← Explorar canciones
        </a>
      </p>
    </div>
  </div>
</Layout>
