---
import "../styles/global.css";
import { getCategorias } from "../lib/supabase";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Alabanzas Cristinas",
  description = "Letras de adoraciones y alabanzas cristianas",
} = Astro.props;

const categorias = await getCategorias();
const url = new URL(Astro.request.url);
const currentCat = url.searchParams.get("cat") ?? "todas";
const currentQ   = url.searchParams.get("q") ?? "";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>✝</text></svg>" />
    <title>{title}</title>
    <slot name="head" />
    <!-- Anti-flash: aplica el tema antes de que el browser pinte -->
    <script is:inline>
      (function(){
        var t=localStorage.getItem('theme')||'auto';
        if(t==='light'){document.documentElement.setAttribute('data-theme','light');}
        else if(t==='dark'){document.documentElement.setAttribute('data-theme','dark');}
        else{var dark=window.matchMedia('(prefers-color-scheme:dark)').matches;document.documentElement.setAttribute('data-theme',dark?'dark':'light');}
      })();
    </script>
  </head>

  <body>
    <div class="bg-scene" aria-hidden="true"></div>

    <!-- ── OPTIONS PANEL (derecha) ──────────────────────────── -->
    <div class="opts-overlay" id="opts-overlay" aria-hidden="true"></div>

    <aside class="opts-panel" id="opts-panel" aria-label="Opciones" aria-hidden="true">
      <div class="opts-header">
        <span class="opts-title">Opciones</span>
        <button class="opts-close-btn" id="opts-close-btn" aria-label="Cerrar opciones">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Tarjeta login -->
      <div class="opts-login-card">
        <div class="opts-login-icon" aria-hidden="true">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
        </div>
        <div class="opts-login-text">
          <p>Inicia sesión para administrar canciones, artistas y categorías.</p>
        </div>
        <a href="/admin/login" class="opts-login-btn">Iniciar sesión</a>
      </div>

      <!-- Sección Pantalla -->
      <div class="opts-section">
        <div class="opts-section-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
          </svg>
          <span class="opts-section-label">Pantalla</span>
        </div>
        <div class="opts-theme-btns">
          <button class="theme-btn" data-theme-val="auto">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            Automático
          </button>
          <button class="theme-btn" data-theme-val="light">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
            Claro
          </button>
          <button class="theme-btn" data-theme-val="dark">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            Oscuro
          </button>
        </div>
      </div>

      <!-- Sección Agregar canción -->
      <div class="opts-section opts-section--link">
        <a href="/admin/login" class="opts-action-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
          </svg>
          Agregar letras y más
        </a>
      </div>
    </aside>

    <!-- ── SLIDE-OUT MENU PANEL ──────────────────────────────── -->
    <div class="menu-overlay" id="menu-overlay" aria-hidden="true"></div>

    <nav class="menu-panel" id="menu-panel" aria-label="Menú principal" aria-hidden="true">
      <div class="menu-panel-header">
        <span class="menu-panel-title">Menú</span>
        <button class="menu-close-btn" id="menu-close-btn" aria-label="Cerrar menú">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <ul class="menu-panel-nav">
        <li>
          <a href="/" class="menu-panel-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
            </svg>
            Canciones
          </a>
        </li>
        <li>
          <a href="/?cat=todas" class="menu-panel-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
              <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            Géneros
          </a>
        </li>
        <li>
          <a href="/" class="menu-panel-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
            Artistas
          </a>
        </li>
        <li>
          <a href="/" class="menu-panel-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 2a3 3 0 0 0-3 3v4H4l1 12h14l1-12h-5V5a3 3 0 0 0-3-3z"/>
            </svg>
            Adoración
          </a>
        </li>
      </ul>

      <div class="menu-panel-cats">
        <p class="menu-panel-cats-title">Géneros</p>
        <a href="/?cat=todas" class="menu-panel-cat-link"
          aria-current={currentCat === "todas" ? "page" : undefined}>Todas</a>
        {categorias.map((c) => (
          <a href={`/?cat=${c.slug}`} class="menu-panel-cat-link"
            aria-current={currentCat === c.slug ? "page" : undefined}>{c.nombre}</a>
        ))}
      </div>

      <div class="menu-panel-footer">
        <a href="/" class="menu-panel-cta">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          Agregar letra
        </a>
      </div>
    </nav>

    <!-- ── HEADER ─────────────────────────────────────────── -->
    <header class="topbar">
      <div class="topbar-inner container">

        <button class="mobile-menu-btn" id="menu-open-btn" aria-label="Abrir menú" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>

        <a href="/" class="topbar-logo">
          <span class="logo-cross">✝</span>
          <span class="logo-text">Alabanzas</span>
        </a>

        <form class="topbar-search" action="/" method="get" role="search">
          {currentCat !== "todas" && <input type="hidden" name="cat" value={currentCat} />}
          <input
            id="header-search"
            class="topbar-search-input"
            type="search"
            name="q"
            value={currentQ}
            placeholder="¿Qué alabanza quieres encontrar?"
            autocomplete="off"
            aria-label="Buscar canciones"
          />
          <button class="topbar-search-btn" type="submit" aria-label="Buscar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </button>
        </form>

        <button class="options-btn" id="options-open-btn" aria-label="Opciones">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
          <span class="options-btn-label">Iniciar sesión</span>
        </button>

      </div>

      <!-- ── CATEGORY PILLS BAR ─────────────────────────────── -->
      <div class="cat-bar">
        <div class="cat-bar-inner container">
          <a href="/?cat=todas" class="cat-pill"
            aria-current={currentCat === "todas" ? "page" : undefined}>Todas</a>
          {categorias.map((c) => (
            <a href={`/?cat=${c.slug}`} class="cat-pill"
              aria-current={currentCat === c.slug ? "page" : undefined}>{c.nombre}</a>
          ))}
        </div>
      </div>
    </header>

    <!-- ── MAIN ───────────────────────────────────────────── -->
    <div class="page">
      <slot />
    </div>

    <!-- ── FOOTER ─────────────────────────────────────────── -->
    <footer class="site-footer">

      <!-- 3 tarjetas -->
      <div class="footer-cards container">

        <div class="footer-card">
          <h3 class="footer-card-title">Explorar</h3>
          <ul class="footer-card-links">
            <li><a href="/">Canciones</a></li>
            <li><a href="/?cat=todas">Todos los géneros</a></li>
            {categorias.slice(0, 4).map((c) => (
              <li><a href={`/?cat=${c.slug}`}>{c.nombre}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer-card">
          <h3 class="footer-card-title">Géneros</h3>
          <ul class="footer-card-links">
            {categorias.map((c) => (
              <li><a href={`/?cat=${c.slug}`}>{c.nombre}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer-card">
          <h3 class="footer-card-title">Sobre el sitio</h3>
          <ul class="footer-card-links">
            <li><a href="/">Inicio</a></li>
            <li><a href="/?cat=todas">Ver todas las canciones</a></li>
            <li class="footer-card-desc">
              Un espacio dedicado a preservar las letras de alabanzas y adoraciones en español para la comunidad cristiana.
            </li>
          </ul>
        </div>

      </div>

      <!-- Barra inferior -->
      <div class="footer-bottom">
        <div class="footer-bottom-inner container">
          <p class="footer-logo-sm">
            <span class="logo-cross">✝</span> Alabanzas Cristinas
          </p>

          <div class="theme-switcher">
            <span class="theme-switcher-label">Pantalla</span>
            <button class="theme-btn" data-theme-val="auto">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
              Automático
            </button>
            <button class="theme-btn" data-theme-val="light">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
              Claro
            </button>
            <button class="theme-btn" data-theme-val="dark">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              Oscuro
            </button>
          </div>

          <p class="footer-copy">&copy; {new Date().getFullYear()} Alabanzas Cristinas</p>
        </div>
      </div>

    </footer>

    <script>
      // ── Menu panel ──────────────────────────────────────────
      const openBtn  = document.getElementById('menu-open-btn');
      const closeBtn = document.getElementById('menu-close-btn');
      const overlay  = document.getElementById('menu-overlay');
      const panel    = document.getElementById('menu-panel');

      function openMenu() {
        panel?.classList.add('open');
        overlay?.classList.add('open');
        panel?.setAttribute('aria-hidden', 'false');
        overlay?.setAttribute('aria-hidden', 'false');
        openBtn?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
      function closeMenu() {
        panel?.classList.remove('open');
        overlay?.classList.remove('open');
        panel?.setAttribute('aria-hidden', 'true');
        overlay?.setAttribute('aria-hidden', 'true');
        openBtn?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      openBtn?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      overlay?.addEventListener('click', closeMenu);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeMenu(); closeOpts(); } });

      // ── Options panel (derecha) ─────────────────────────────
      const optsOpenBtn  = document.getElementById('options-open-btn');
      const optsCloseBtn = document.getElementById('opts-close-btn');
      const optsOverlay  = document.getElementById('opts-overlay');
      const optsPanel    = document.getElementById('opts-panel');

      function openOpts() {
        optsPanel?.classList.add('open');
        optsOverlay?.classList.add('open');
        optsPanel?.setAttribute('aria-hidden', 'false');
        optsOverlay?.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
      function closeOpts() {
        optsPanel?.classList.remove('open');
        optsOverlay?.classList.remove('open');
        optsPanel?.setAttribute('aria-hidden', 'true');
        optsOverlay?.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      optsOpenBtn?.addEventListener('click', openOpts);
      optsCloseBtn?.addEventListener('click', closeOpts);
      optsOverlay?.addEventListener('click', closeOpts);

      // ── Theme switcher ──────────────────────────────────────
      const root = document.documentElement;
      const saved = localStorage.getItem('theme') || 'auto';

      function applyTheme(t: string) {
        if (t === 'auto') {
          const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          root.setAttribute('data-theme', dark ? 'dark' : 'light');
        } else {
          root.setAttribute('data-theme', t);
        }
      }

      function syncButtons(active: string) {
        document.querySelectorAll<HTMLButtonElement>('[data-theme-val]').forEach(btn => {
          btn.classList.toggle('theme-btn--active', btn.dataset.themeVal === active);
        });
      }

      syncButtons(saved);

      document.querySelectorAll<HTMLButtonElement>('[data-theme-val]').forEach(btn => {
        btn.addEventListener('click', () => {
          const t = btn.dataset.themeVal!;
          localStorage.setItem('theme', t);
          applyTheme(t);
          syncButtons(t);
        });
      });

      // Seguir cambios del sistema cuando está en "auto"
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if ((localStorage.getItem('theme') || 'auto') === 'auto') applyTheme('auto');
      });
    </script>
  </body>
</html>
