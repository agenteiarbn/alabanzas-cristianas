---
import "../styles/global.css";
import { getCategorias } from "../lib/supabase";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Alabanzas Cristianas",
  description = "Letras de adoraciones y alabanzas cristianas",
} = Astro.props;

const categorias = await getCategorias();
const url = new URL(Astro.request.url);
const currentCat = url.searchParams.get("cat") ?? "todas";
const currentQ   = url.searchParams.get("q") ?? "";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>✝</text></svg>" />
    <title>{title}</title>
    <slot name="head" />
    <!-- Anti-flash: aplica el tema antes de que el browser pinte -->
    <script is:inline>
      (function(){
        var t=localStorage.getItem('theme')||'auto';
        if(t==='light'){document.documentElement.setAttribute('data-theme','light');}
        else if(t==='dark'){document.documentElement.setAttribute('data-theme','dark');}
        else{var dark=window.matchMedia('(prefers-color-scheme:dark)').matches;document.documentElement.setAttribute('data-theme',dark?'dark':'light');}
      })();
    </script>
  </head>

  <body>
    <div class="bg-scene" aria-hidden="true"></div>

    <!-- ── AUTH MODAL (centrado) ─────────────────────────────── -->
    <div class="auth-overlay" id="auth-overlay" aria-hidden="true">
      <div class="auth-modal" role="dialog" aria-modal="true" aria-label="Iniciar sesión">

        <!-- Panel izquierdo decorativo -->
        <div class="auth-left" aria-hidden="true">
          <div class="auth-left-brand">
            <span class="auth-left-cross">✝</span>
            <span>Alabanzas Cristianas</span>
          </div>
          <h2 class="auth-left-headline">Más formas de explorar la alabanza</h2>
          <div class="auth-left-card">
            <span class="auth-left-badge">Nuevas funciones para ti</span>
            <ul class="auth-left-features">
              <li>Guarda tus canciones favoritas.</li>
              <li>Crea listas de adoración.</li>
              <li>Recibe sugerencias personalizadas.</li>
            </ul>
          </div>
        </div>

        <!-- Panel derecho: formularios -->
        <div class="auth-right">
          <button class="auth-close" id="auth-close" aria-label="Cerrar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>

          <!-- Vista: opciones de login -->
          <div class="auth-view" id="auth-view-options">
            <h2 class="auth-view-title">Iniciar sesión</h2>
            <div class="auth-providers">
              <button class="auth-provider-btn" id="auth-email-toggle">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                Usar correo y contraseña
              </button>
              <button class="auth-provider-btn auth-provider-btn--google" id="auth-google-btn">
                <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                Continuar con Google
              </button>
              <button class="auth-provider-btn auth-provider-btn--facebook" id="auth-facebook-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="#1877F2"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Continuar con Facebook
              </button>
              <button class="auth-provider-btn auth-provider-btn--apple" id="auth-apple-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                Continuar con Apple
              </button>
            </div>
            <p class="auth-forgot"><a href="#" id="auth-show-forgot">Olvidé mi contraseña</a></p>
            <p class="auth-switch">¿No tienes una cuenta? <a href="#" id="auth-show-register">Regístrate</a></p>
          </div>

          <!-- Vista: login con correo -->
          <div class="auth-view" id="auth-view-email" hidden>
            <button class="auth-back" id="auth-back-from-email">← Otras opciones</button>
            <h2 class="auth-view-title">Iniciar sesión</h2>
            <form class="auth-form" id="auth-login-form" novalidate>
              <div class="auth-field">
                <label for="login-email">Correo electrónico</label>
                <input id="login-email" name="email" type="email" autocomplete="email" required placeholder="tu@correo.com" />
              </div>
              <div class="auth-field">
                <label for="login-password">Contraseña</label>
                <input id="login-password" name="password" type="password" autocomplete="current-password" required placeholder="••••••••" />
              </div>
              <p class="auth-msg auth-msg--error" id="login-error" hidden></p>
              <button type="submit" class="auth-submit" id="login-submit">Entrar</button>
            </form>
            <p class="auth-switch">¿No tienes una cuenta? <a href="#" id="auth-email-to-register">Regístrate</a></p>
          </div>

          <!-- Vista: registro -->
          <div class="auth-view" id="auth-view-register" hidden>
            <button class="auth-back" id="auth-back-from-register">← Iniciar sesión</button>
            <h2 class="auth-view-title">Crear cuenta</h2>
            <form class="auth-form" id="auth-register-form" novalidate>
              <div class="auth-field">
                <label for="reg-name">Nombre</label>
                <input id="reg-name" name="name" type="text" autocomplete="name" required placeholder="Tu nombre" />
              </div>
              <div class="auth-field">
                <label for="reg-email">Correo electrónico</label>
                <input id="reg-email" name="email" type="email" autocomplete="email" required placeholder="tu@correo.com" />
              </div>
              <div class="auth-field">
                <label for="reg-password">Contraseña</label>
                <input id="reg-password" name="password" type="password" autocomplete="new-password" required placeholder="Mínimo 6 caracteres" />
              </div>
              <p class="auth-msg auth-msg--error" id="register-error" hidden></p>
              <p class="auth-msg auth-msg--success" id="register-success" hidden>¡Cuenta creada! Revisa tu correo para confirmarla.</p>
              <button type="submit" class="auth-submit" id="register-submit">Crear cuenta</button>
            </form>
          </div>

          <!-- Vista: recuperar contraseña -->
          <div class="auth-view" id="auth-view-forgot" hidden>
            <button class="auth-back" id="auth-back-from-forgot">← Iniciar sesión</button>
            <h2 class="auth-view-title">Recuperar contraseña</h2>
            <p class="auth-view-desc">Ingresa tu correo y te enviaremos un enlace para restablecer tu contraseña.</p>
            <form class="auth-form" id="auth-forgot-form" novalidate>
              <div class="auth-field">
                <label for="forgot-email">Correo electrónico</label>
                <input id="forgot-email" name="email" type="email" required placeholder="tu@correo.com" />
              </div>
              <p class="auth-msg auth-msg--error" id="forgot-error" hidden></p>
              <p class="auth-msg auth-msg--success" id="forgot-success" hidden>Revisa tu correo para el enlace de recuperación.</p>
              <button type="submit" class="auth-submit" id="forgot-submit">Enviar enlace</button>
            </form>
          </div>

          <!-- Vista: sesión activa (perfil) -->
          <div class="auth-view" id="auth-view-profile" hidden>
            <div class="auth-user-avatar" id="auth-user-avatar">U</div>
            <h2 class="auth-user-name" id="auth-user-name">Usuario</h2>
            <p class="auth-user-email" id="auth-user-email">—</p>
            <div class="auth-user-actions">
              <a href="/perfil" class="auth-profile-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                Ver mi perfil
              </a>
              <button class="auth-logout-btn" id="auth-logout-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/></svg>
                Cerrar sesión
              </button>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- ── SLIDE-OUT MENU PANEL ──────────────────────────────── -->
    <div class="menu-overlay" id="menu-overlay" aria-hidden="true"></div>

    <nav class="menu-panel" id="menu-panel" aria-label="Menú principal" aria-hidden="true">
      <div class="menu-panel-header">
        <span class="menu-panel-title">Menú</span>
        <button class="menu-close-btn" id="menu-close-btn" aria-label="Cerrar menú">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <ul class="menu-panel-nav">
        <li>
          <a href="/" class="menu-panel-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
            </svg>
            Canciones
          </a>
        </li>
        <li>
          <a href="/?cat=todas" class="menu-panel-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
              <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            Géneros
          </a>
        </li>
        <li>
          <a href="/" class="menu-panel-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
            Artistas
          </a>
        </li>
        <li>
          <a href="/" class="menu-panel-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M12 2a3 3 0 0 0-3 3v4H4l1 12h14l1-12h-5V5a3 3 0 0 0-3-3z"/>
            </svg>
            Adoración
          </a>
        </li>
      </ul>

      <div class="menu-panel-cats">
        <p class="menu-panel-cats-title">Géneros</p>
        <a href="/?cat=todas" class="menu-panel-cat-link"
          aria-current={currentCat === "todas" ? "page" : undefined}>Todas</a>
        {categorias.map((c) => (
          <a href={`/?cat=${c.slug}`} class="menu-panel-cat-link"
            aria-current={currentCat === c.slug ? "page" : undefined}>{c.nombre}</a>
        ))}
      </div>

      <div class="menu-panel-footer">
        <a href="/" class="menu-panel-cta">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 5v14M5 12h14"/>
          </svg>
          Agregar letra
        </a>
      </div>
    </nav>

    <!-- ── HEADER ─────────────────────────────────────────── -->
    <header class="topbar">
      <div class="topbar-inner container">

        <button class="mobile-menu-btn" id="menu-open-btn" aria-label="Abrir menú" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>

        <a href="/" class="topbar-logo">
          <span class="logo-cross">✝</span>
          <span class="logo-text">Alabanzas</span>
        </a>

        <form class="topbar-search" action="/" method="get" role="search">
          {currentCat !== "todas" && <input type="hidden" name="cat" value={currentCat} />}
          <input
            id="header-search"
            class="topbar-search-input"
            type="search"
            name="q"
            value={currentQ}
            placeholder="¿Qué alabanza quieres encontrar?"
            autocomplete="off"
            aria-label="Buscar canciones"
          />
          <button class="topbar-search-btn" type="submit" aria-label="Buscar">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </button>
        </form>

        <button class="options-btn" id="options-open-btn" aria-label="Opciones">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
          </svg>
          <span class="options-btn-label">Iniciar sesión</span>
        </button>

      </div>

      <!-- ── CATEGORY PILLS BAR ─────────────────────────────── -->
      <div class="cat-bar">
        <div class="cat-bar-inner container">
          <a href="/?cat=todas" class="cat-pill"
            aria-current={currentCat === "todas" ? "page" : undefined}>Todas</a>
          {categorias.map((c) => (
            <a href={`/?cat=${c.slug}`} class="cat-pill"
              aria-current={currentCat === c.slug ? "page" : undefined}>{c.nombre}</a>
          ))}
        </div>
      </div>
    </header>

    <!-- ── MAIN ───────────────────────────────────────────── -->
    <div class="page">
      <slot />
    </div>

    <!-- ── FOOTER ─────────────────────────────────────────── -->
    <footer class="site-footer">

      <!-- ① 3 tarjetas -->
      <div class="footer-cards container">
        <div class="footer-card">
          <h3 class="footer-card-title">Explorar</h3>
          <ul class="footer-card-links">
            <li><a href="/">Canciones</a></li>
            <li><a href="/?cat=todas">Todos los géneros</a></li>
            {categorias.slice(0, 5).map((c) => (
              <li><a href={`/?cat=${c.slug}`}>{c.nombre}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-card">
          <h3 class="footer-card-title">Participa</h3>
          <ul class="footer-card-links">
            <li><a href="/admin/login">Agregar una canción</a></li>
            <li><a href="/admin/login">Agregar un artista</a></li>
            <li><a href="/admin/login">Agregar un género</a></li>
            <li><a href="/admin/login">Corregir una letra</a></li>
          </ul>
        </div>
        <div class="footer-card">
          <h3 class="footer-card-title">Sobre el sitio</h3>
          <ul class="footer-card-links">
            <li><a href="/">Inicio</a></li>
            <li><a href="/?cat=todas">Ver todas las canciones</a></li>
            <li><a href="/admin/login">Panel de administración</a></li>
            <li class="footer-card-desc">
              Un espacio dedicado a preservar las letras de alabanzas y adoraciones en español.
            </li>
          </ul>
        </div>
      </div>

      <!-- ② Fila de columnas: Pantalla + otros -->
      <div class="footer-info">
        <div class="footer-info-inner container">

          <div class="footer-info-col">
            <p class="footer-info-title">Géneros destacados</p>
            <div class="footer-info-links">
              {categorias.map((c) => (
                <a href={`/?cat=${c.slug}`} class="footer-info-link">{c.nombre}</a>
              ))}
            </div>
          </div>

          <div class="footer-info-col">
            <p class="footer-info-title">Comunidad</p>
            <div class="footer-info-links">
              <a href="/admin/login" class="footer-info-link">Inicia sesión</a>
              <a href="/admin/login" class="footer-info-link">Agrega letras</a>
              <a href="/admin/login" class="footer-info-link">Administrar sitio</a>
            </div>
          </div>

          <div class="footer-info-col footer-info-col--pantalla">
            <p class="footer-info-title">Pantalla</p>
            <div class="footer-pantalla">
              <button class="footer-pantalla-opt" data-theme-val="auto">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
                Automático
              </button>
              <span class="footer-pantalla-sep">·</span>
              <button class="footer-pantalla-opt" data-theme-val="light">Claro</button>
              <span class="footer-pantalla-sep">·</span>
              <button class="footer-pantalla-opt" data-theme-val="dark">Oscuro</button>
            </div>
          </div>

        </div>
      </div>

      <!-- ③ Síguenos -->
      <div class="footer-social">
        <div class="footer-social-inner container">
          <p class="footer-social-title">Síguenos en</p>
          <div class="footer-social-pills">
            <a href="#" class="footer-social-pill">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              Instagram
            </a>
            <a href="#" class="footer-social-pill">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
            <a href="#" class="footer-social-pill">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </a>
            <a href="#" class="footer-social-pill">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.27 8.27 0 004.84 1.55V6.79a4.85 4.85 0 01-1.07-.1z"/></svg>
              TikTok
            </a>
          </div>
        </div>
      </div>

      <!-- ④ Barra de copyright -->
      <div class="footer-bottom">
        <div class="footer-bottom-inner container">
          <p class="footer-logo-sm">
            <span class="logo-cross">✝</span> Alabanzas Cristianas
          </p>
          <p class="footer-copy">&copy; {new Date().getFullYear()} Alabanzas Cristianas — Letras de adoración en español</p>
        </div>
      </div>

    </footer>

    <script>
      import { createClient } from '@supabase/supabase-js';

      // ── Supabase ─────────────────────────────────────────────
      const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY
      );

      // ── Menu panel (izquierda) ───────────────────────────────
      const menuOpenBtn  = document.getElementById('menu-open-btn');
      const menuCloseBtn = document.getElementById('menu-close-btn');
      const menuOverlay  = document.getElementById('menu-overlay');
      const menuPanel    = document.getElementById('menu-panel');

      function openMenu() {
        menuPanel?.classList.add('open');
        menuOverlay?.classList.add('open');
        menuPanel?.setAttribute('aria-hidden', 'false');
        menuOverlay?.setAttribute('aria-hidden', 'false');
        menuOpenBtn?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
      function closeMenu() {
        menuPanel?.classList.remove('open');
        menuOverlay?.classList.remove('open');
        menuPanel?.setAttribute('aria-hidden', 'true');
        menuOverlay?.setAttribute('aria-hidden', 'true');
        menuOpenBtn?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
      menuOpenBtn?.addEventListener('click', openMenu);
      menuCloseBtn?.addEventListener('click', closeMenu);
      menuOverlay?.addEventListener('click', closeMenu);

      // ── Auth modal ───────────────────────────────────────────
      const authOverlay = document.getElementById('auth-overlay');
      const authClose   = document.getElementById('auth-close');
      const optsBtn     = document.getElementById('options-open-btn');

      async function openAuth() {
        const { data: { user } } = await supabase.auth.getUser();
        showView(user ? 'auth-view-profile' : 'auth-view-options');
        authOverlay?.classList.add('open');
        authOverlay?.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      }
      function closeAuth() {
        authOverlay?.classList.remove('open');
        authOverlay?.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      optsBtn?.addEventListener('click', openAuth);
      authClose?.addEventListener('click', closeAuth);
      authOverlay?.addEventListener('click', (e) => { if (e.target === authOverlay) closeAuth(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeMenu(); closeAuth(); } });

      // ── View switching ───────────────────────────────────────
      function showView(id: string) {
        document.querySelectorAll<HTMLDivElement>('.auth-view').forEach(v => {
          v.hidden = v.id !== id;
        });
      }

      document.getElementById('auth-email-toggle')?.addEventListener('click', () => showView('auth-view-email'));
      document.getElementById('auth-back-from-email')?.addEventListener('click', () => showView('auth-view-options'));
      document.getElementById('auth-show-register')?.addEventListener('click', (e) => { e.preventDefault(); showView('auth-view-register'); });
      document.getElementById('auth-email-to-register')?.addEventListener('click', (e) => { e.preventDefault(); showView('auth-view-register'); });
      document.getElementById('auth-back-from-register')?.addEventListener('click', () => showView('auth-view-options'));
      document.getElementById('auth-show-forgot')?.addEventListener('click', (e) => { e.preventDefault(); showView('auth-view-forgot'); });
      document.getElementById('auth-back-from-forgot')?.addEventListener('click', () => showView('auth-view-options'));

      // ── OAuth ────────────────────────────────────────────────
      async function signInWith(provider: 'google' | 'facebook' | 'apple') {
        const { error } = await supabase.auth.signInWithOAuth({
          provider,
          options: { redirectTo: window.location.origin }
        });
        if (error) console.error(error.message);
      }
      document.getElementById('auth-google-btn')?.addEventListener('click', () => signInWith('google'));
      document.getElementById('auth-facebook-btn')?.addEventListener('click', () => signInWith('facebook'));
      document.getElementById('auth-apple-btn')?.addEventListener('click', () => signInWith('apple'));

      // ── Email login ──────────────────────────────────────────
      const loginForm = document.getElementById('auth-login-form') as HTMLFormElement;
      loginForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submit  = document.getElementById('login-submit') as HTMLButtonElement;
        const errorEl = document.getElementById('login-error');
        const email    = (document.getElementById('login-email') as HTMLInputElement).value;
        const password = (document.getElementById('login-password') as HTMLInputElement).value;
        submit.disabled = true;
        submit.textContent = 'Entrando…';
        if (errorEl) errorEl.hidden = true;
        const { error } = await supabase.auth.signInWithPassword({ email, password });
        if (error) {
          if (errorEl) { errorEl.textContent = 'Correo o contraseña incorrectos.'; errorEl.hidden = false; }
          submit.disabled = false; submit.textContent = 'Entrar';
        } else { closeAuth(); window.location.reload(); }
      });

      // ── Register ─────────────────────────────────────────────
      const registerForm = document.getElementById('auth-register-form') as HTMLFormElement;
      registerForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submit    = document.getElementById('register-submit') as HTMLButtonElement;
        const errorEl   = document.getElementById('register-error');
        const successEl = document.getElementById('register-success');
        const name      = (document.getElementById('reg-name') as HTMLInputElement).value.trim();
        const email     = (document.getElementById('reg-email') as HTMLInputElement).value;
        const password  = (document.getElementById('reg-password') as HTMLInputElement).value;
        submit.disabled = true; submit.textContent = 'Creando cuenta…';
        if (errorEl) errorEl.hidden = true;
        if (successEl) successEl.hidden = true;
        const { error } = await supabase.auth.signUp({
          email, password,
          options: { data: { full_name: name, display_name: name } }
        });
        if (error) {
          if (errorEl) { errorEl.textContent = error.message; errorEl.hidden = false; }
          submit.disabled = false; submit.textContent = 'Crear cuenta';
        } else {
          if (successEl) successEl.hidden = false;
          submit.textContent = '¡Revisa tu correo!';
        }
      });

      // ── Forgot password ──────────────────────────────────────
      const forgotForm = document.getElementById('auth-forgot-form') as HTMLFormElement;
      forgotForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submit    = document.getElementById('forgot-submit') as HTMLButtonElement;
        const errorEl   = document.getElementById('forgot-error');
        const successEl = document.getElementById('forgot-success');
        const email     = (document.getElementById('forgot-email') as HTMLInputElement).value;
        submit.disabled = true;
        if (errorEl) errorEl.hidden = true;
        if (successEl) successEl.hidden = true;
        const { error } = await supabase.auth.resetPasswordForEmail(email, {
          redirectTo: window.location.origin + '/perfil'
        });
        if (error) {
          if (errorEl) { errorEl.textContent = error.message; errorEl.hidden = false; }
          submit.disabled = false;
        } else {
          if (successEl) successEl.hidden = false;
          submit.textContent = '¡Enviado!';
        }
      });

      // ── Logout ───────────────────────────────────────────────
      document.getElementById('auth-logout-btn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        closeAuth();
        window.location.reload();
      });

      // ── Update UI based on auth state ────────────────────────
      function updateHeaderBtn(user: any) {
        const labelEl = document.querySelector<HTMLElement>('.options-btn-label');
        if (!labelEl) return;
        if (user) {
          const name = user.user_metadata?.display_name || user.user_metadata?.full_name
            || user.email?.split('@')[0] || 'Perfil';
          labelEl.textContent = name.split(' ')[0];
        } else {
          labelEl.textContent = 'Iniciar sesión';
        }
      }

      function updateProfileView(user: any) {
        const name = user.user_metadata?.display_name || user.user_metadata?.full_name
          || user.email?.split('@')[0] || 'Usuario';
        const initial = name.charAt(0).toUpperCase();
        const avatarEl = document.getElementById('auth-user-avatar');
        const nameEl   = document.getElementById('auth-user-name');
        const emailEl  = document.getElementById('auth-user-email');
        if (avatarEl) avatarEl.textContent = initial;
        if (nameEl)   nameEl.textContent   = name;
        if (emailEl)  emailEl.textContent  = user.email || '';
      }

      supabase.auth.onAuthStateChange((_event, session) => {
        const user = session?.user ?? null;
        updateHeaderBtn(user);
        if (user) { updateProfileView(user); loadFavorites(); }
      });

      supabase.auth.getUser().then(({ data: { user } }) => {
        updateHeaderBtn(user);
        if (user) { updateProfileView(user); loadFavorites(); }
      });

      // ── Favorites ────────────────────────────────────────────
      let favIds = new Set<number>();

      async function loadFavorites() {
        try {
          const { data: { user } } = await supabase.auth.getUser();
          if (!user) return;
          const { data } = await supabase
            .from('favoritos')
            .select('cancion_id')
            .eq('user_id', user.id);
          if (!data) return;
          favIds = new Set(data.map((f: any) => Number(f.cancion_id)));
          document.querySelectorAll<HTMLElement>('[data-heart]').forEach(btn => {
            const id = Number(btn.dataset.id);
            const isFav = favIds.has(id);
            btn.classList.toggle('favorito', isFav);
            btn.setAttribute('title', isFav ? 'Quitar de favoritos' : 'Guardar en favoritos');
          });
        } catch (_) {}
      }

      document.addEventListener('click', async (e) => {
        const btn = (e.target as Element)?.closest<HTMLElement>('[data-heart]');
        if (!btn) return;
        e.preventDefault();
        e.stopPropagation();
        const { data: { user } } = await supabase.auth.getUser();
        if (!user) { showView('auth-view-options'); openAuth(); return; }
        const cancionId = Number(btn.dataset.id);
        const isFav = favIds.has(cancionId);
        try {
          if (isFav) {
            await supabase.from('favoritos').delete()
              .eq('user_id', user.id).eq('cancion_id', cancionId);
            favIds.delete(cancionId);
          } else {
            await supabase.from('favoritos').insert({ user_id: user.id, cancion_id: cancionId });
            favIds.add(cancionId);
          }
          btn.classList.toggle('favorito', !isFav);
          btn.setAttribute('title', !isFav ? 'Quitar de favoritos' : 'Guardar en favoritos');
        } catch (_) {}
      });

      // ── Theme switcher ───────────────────────────────────────
      const root  = document.documentElement;
      const saved = localStorage.getItem('theme') || 'auto';

      function applyTheme(t: string) {
        if (t === 'auto') {
          const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          root.setAttribute('data-theme', dark ? 'dark' : 'light');
        } else {
          root.setAttribute('data-theme', t);
        }
      }

      function syncButtons(active: string) {
        document.querySelectorAll<HTMLButtonElement>('[data-theme-val]').forEach(btn => {
          const on = btn.dataset.themeVal === active;
          btn.classList.toggle('theme-btn--active', on);
          btn.classList.toggle('footer-pantalla-opt--active', on);
        });
      }

      syncButtons(saved);

      document.querySelectorAll<HTMLButtonElement>('[data-theme-val]').forEach(btn => {
        btn.addEventListener('click', () => {
          const t = btn.dataset.themeVal!;
          localStorage.setItem('theme', t);
          applyTheme(t);
          syncButtons(t);
        });
      });

      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if ((localStorage.getItem('theme') || 'auto') === 'auto') applyTheme('auto');
      });
    </script>
  </body>
</html>
