---
import "../styles/global.css";
import { getCategorias } from "../lib/supabase";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Alabanzas Cristinas",
  description = "Letras de adoraciones y alabanzas cristianas",
} = Astro.props;

const categorias = await getCategorias();
const url = new URL(Astro.request.url);
const currentCat = url.searchParams.get("cat") ?? "todas";
const currentQ   = url.searchParams.get("q") ?? "";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>✝</text></svg>" />
    <title>{title}</title>
    <slot name="head" />
  </head>

  <body>
    <div class="bg-scene" aria-hidden="true"></div>

    <!-- ── HEADER ─────────────────────────────────────────── -->
    <header class="topbar">
      <div class="topbar-inner container">

        <a href="/" class="topbar-logo">
          <span class="logo-cross">✝</span>
          <span class="logo-text">Alabanzas</span>
        </a>

        <nav class="topbar-nav" aria-label="Categorías">
          <a href="/?cat=todas"
            class="topbar-nav-link"
            aria-current={currentCat === "todas" ? "page" : undefined}>
            Todas
          </a>
          {categorias.map((c) => (
            <a
              href={`/?cat=${c.slug}`}
              class="topbar-nav-link"
              aria-current={currentCat === c.slug ? "page" : undefined}
            >{c.nombre}</a>
          ))}
        </nav>

        <form class="topbar-search" action="/" method="get" role="search">
          {currentCat !== "todas" && <input type="hidden" name="cat" value={currentCat} />}
          <input
            id="header-search"
            class="topbar-search-input"
            type="search"
            name="q"
            value={currentQ}
            placeholder="Buscar canciones…"
            autocomplete="off"
            aria-label="Buscar canciones"
          />
          <button class="topbar-search-btn" type="submit" aria-label="Buscar">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </button>
        </form>

        <button class="mobile-menu-btn" aria-label="Menú" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>

      </div>

      <div class="mobile-nav" aria-hidden="true">
        <a href="/?cat=todas" class="mobile-nav-link">Todas</a>
        {categorias.map((c) => (
          <a href={`/?cat=${c.slug}`} class="mobile-nav-link">{c.nombre}</a>
        ))}
        <form action="/" method="get" style="padding:.75rem 1rem 1rem;">
          <input type="search" name="q" value={currentQ} placeholder="Buscar…"
            style="width:100%;background:rgba(212,175,95,.07);border:1px solid rgba(212,175,95,.2);border-radius:2px;padding:.55rem .85rem;color:var(--text);font-size:.95rem;" />
        </form>
      </div>
    </header>

    <!-- ── MAIN ───────────────────────────────────────────── -->
    <div class="page">
      <slot />
    </div>

    <!-- ── FOOTER ─────────────────────────────────────────── -->
    <footer class="site-footer">
      <div class="footer-inner container">

        <div class="footer-col footer-brand">
          <p class="footer-logo"><span class="logo-cross">✝</span> Alabanzas Cristinas</p>
          <p class="footer-tagline">Letras de canciones que elevan el alma</p>
          <div class="gold-rule" style="margin:1rem 0;"></div>
          <p class="footer-copy">&copy; {new Date().getFullYear()} Alabanzas Cristinas</p>
        </div>

        <div class="footer-col">
          <p class="footer-heading">Navegar</p>
          <ul class="footer-links">
            <li><a href="/?cat=todas">Todas las canciones</a></li>
            {categorias.map((c) => (
              <li><a href={`/?cat=${c.slug}`}>{c.nombre}</a></li>
            ))}
          </ul>
        </div>

        <div class="footer-col">
          <p class="footer-heading">Acerca</p>
          <ul class="footer-links">
            <li><a href="/">Inicio</a></li>
            <li style="color:var(--text-faint);font-style:italic;font-size:.9rem;margin-top:.5rem;">
              Un espacio dedicado a preservar las letras de alabanzas y adoraciones en español.
            </li>
          </ul>
        </div>

      </div>
    </footer>

    <script>
      const btn = document.querySelector('.mobile-menu-btn');
      const nav = document.querySelector('.mobile-nav');
      btn?.addEventListener('click', () => {
        const open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        nav?.setAttribute('aria-hidden', String(open));
        nav?.classList.toggle('open', !open);
      });
    </script>
  </body>
</html>
