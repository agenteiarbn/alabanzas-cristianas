---
import type { Cancion } from "../lib/supabase";

interface Props {
  cancion: Cancion;
  index?: number;
}

const { cancion, index = 0 } = Astro.props;
const primerVerso = cancion.letra.split("\n").find((l) => l.trim() !== "") ?? "";
---

<div class="song-card-wrap">
  <a
    href={`/cancion/${cancion.slug}`}
    class="song-card"
    style={`animation-delay: ${index * 0.05}s`}
  >
    <span class="card-badge">✦ {cancion.categorias.nombre}</span>

    <h2 class="card-title">{cancion.titulo}</h2>
    <p class="card-artist">{cancion.artistas.nombre}</p>

    <p class="card-preview">{primerVerso}</p>

    <div class="card-meta">
      {cancion.tono && <span class="card-tono">{cancion.tono}</span>}
      <span class="card-arrow">→</span>
    </div>
  </a>

  <button
    class="heart-btn"
    data-heart
    data-id={cancion.id}
    title="Guardar en favoritos"
    aria-label="Guardar en favoritos"
  >
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>
  </button>
</div>
